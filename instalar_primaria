instalar_transcricao_automatica() {
  banner
  printf "${WHITE} >> Verificando e instalando API de Transcrição...\n\n"

  local transcricao_dir="/home/deploy/${empresa}/api_transcricao"

  if [ ! -d "$transcricao_dir" ]; then
    printf "${YELLOW} >> Pasta api_transcricao não encontrada. Pulando essa etapa.${WHITE}\n"
    sleep 2
    return 0
  fi

  apt-get update -y >/dev/null 2>&1 || true
  apt-get install -y python3 python3-venv python3-pip python3-full ffmpeg >/dev/null 2>&1 || true

  chown -R deploy:deploy "$transcricao_dir" 2>/dev/null || true

  local entry=""
  for candidate in wsgi.py main.py app.py server.py run.py api.py; do
    if [ -f "${transcricao_dir}/${candidate}" ]; then
      entry="$candidate"
      break
    fi
  done

  if [ -z "$entry" ]; then
    entry="$(find "$transcricao_dir" -maxdepth 1 -type f -name '*.py' ! -name 'setup.py' | head -1 | xargs -r basename)"
  fi

  if [ -z "$entry" ]; then
    printf "${YELLOW} >> Nenhum arquivo Python principal encontrado em api_transcricao. Pulando essa etapa.${WHITE}\n"
    sleep 2
    return 0
  fi

  local venv_dir="${transcricao_dir}/.venv"
  local module_name="${entry%.py}"
  local requirements_file=""
  local framework="python"
  local run_mode="python"
  local start_script="/home/deploy/start-transcricao-${empresa}.sh"

  for req in requirements.txt requirement.txt requirements-prod.txt; do
    if [ -f "${transcricao_dir}/${req}" ]; then
      requirements_file="$req"
      break
    fi
  done

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    cd '${transcricao_dir}'
    rm -rf '${venv_dir}'
    python3 -m venv '${venv_dir}'
    source '${venv_dir}/bin/activate'
    python -m pip install --upgrade pip setuptools wheel
  " || trata_erro "transcricao_venv"

  if [ -n "$requirements_file" ]; then
    sudo -u deploy bash -lc "
      export HOME=/home/deploy
      cd '${transcricao_dir}'
      source '${venv_dir}/bin/activate'
      pip install -r '${requirements_file}'
    " || trata_erro "transcricao_requirements"
  fi

  if [ -f "${transcricao_dir}/.env.example" ] && [ ! -f "${transcricao_dir}/.env" ]; then
    sudo -u deploy bash -lc "
      export HOME=/home/deploy
      cd '${transcricao_dir}'
      cp .env.example .env
    " || trata_erro "transcricao_env_copy"
  fi

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    cd '${transcricao_dir}'

    [ -f .env ] || touch .env

    grep -q '^PORT=' .env || echo 'PORT=4002' >> .env
    grep -q '^FLASK_DEBUG=' .env || echo 'FLASK_DEBUG=0' >> .env
    grep -q '^PYTHONUNBUFFERED=' .env || echo 'PYTHONUNBUFFERED=1' >> .env

    source '${venv_dir}/bin/activate'
    pip install waitress python-dotenv >/dev/null 2>&1 || true
  " || trata_erro "transcricao_env_defaults"

  if grep -q "FastAPI(" "${transcricao_dir}/${entry}" 2>/dev/null; then
    framework="fastapi"
    if grep -q "uvicorn.run" "${transcricao_dir}/${entry}" 2>/dev/null; then
      run_mode="python"
    else
      run_mode="uvicorn"
      sudo -u deploy bash -lc "
        export HOME=/home/deploy
        cd '${transcricao_dir}'
        source '${venv_dir}/bin/activate'
        pip install uvicorn fastapi >/dev/null 2>&1 || true
      "
    fi
  elif grep -q "Flask(" "${transcricao_dir}/${entry}" 2>/dev/null; then
    framework="flask"
    if grep -q "__main__" "${transcricao_dir}/${entry}" 2>/dev/null; then
      run_mode="python"
    else
      run_mode="flask"
      sudo -u deploy bash -lc "
        export HOME=/home/deploy
        cd '${transcricao_dir}'
        source '${venv_dir}/bin/activate'
        pip install flask >/dev/null 2>&1 || true
      "
    fi
  fi

  cat > "$start_script" <<EOF
#!/bin/bash
set -e
export HOME=/home/deploy
export PATH=/usr/local/bin:/usr/bin:\$PATH
export PM2_HOME=/home/deploy/.pm2
export HOST=127.0.0.1
export PORT=4002
export FLASK_DEBUG=0
export PYTHONUNBUFFERED=1

cd "${transcricao_dir}"
source "${venv_dir}/bin/activate"

FRAMEWORK="${framework}"
RUN_MODE="${run_mode}"
ENTRY_FILE="${entry}"
MODULE_NAME="${module_name}"

if [ "\$FRAMEWORK" = "fastapi" ] && [ "\$RUN_MODE" = "uvicorn" ]; then
  exec uvicorn "\${MODULE_NAME}:app" --host 127.0.0.1 --port 4002
elif [ "\$FRAMEWORK" = "flask" ] && [ "\$RUN_MODE" = "flask" ]; then
  export FLASK_APP="\${MODULE_NAME}:app"
  exec flask run --host 127.0.0.1 --port 4002
else
  exec python "\${ENTRY_FILE}"
fi
EOF

  chmod +x "$start_script"
  chown deploy:deploy "$start_script"

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    export PATH=/usr/local/bin:/usr/bin:\$PATH
    export PM2_HOME=/home/deploy/.pm2

    pm2 delete '${empresa}-transcricao' 2>/dev/null || true
    pm2 start '${start_script}' --name '${empresa}-transcricao' --update-env
    pm2 save
    pm2 list
  " || trata_erro "api_transcricao_pm2"

  local http_code
  http_code="$(curl -s -o /dev/null -w '%{http_code}' 'http://127.0.0.1:4002/' || true)"
  printf "${WHITE} >> HTTP local da transcrição: ${YELLOW}%s${WHITE}\n" "$http_code"

  printf "${GREEN} >> Etapa de transcrição concluída.${WHITE}\n"
  sleep 2
}

