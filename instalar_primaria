confirmar_dados() {
  mostrar_resumo
  printf "${WHITE}Os dados estão corretos? (${GREEN}S${WHITE}/${RED}N${WHITE}):\n\n"
  read -r -p "> " confirmacao
  confirmacao=$(echo "${confirmacao}" | tr '[:lower:]' '[:upper:]')
  echo

  if [ "${confirmacao}" != "S" ]; then
    printf "${YELLOW}>> Instalação cancelada. Rode o script novamente para informar os dados.${WHITE}\n"
    exit 0
  fi
}

verificar_dns() {
  banner
  printf "${WHITE} >> Verificando DNS (apenas aviso, não trava instalação)...\n\n"
  sleep 2

  if ! command -v dig >/dev/null 2>&1; then
    apt-get update -y >/dev/null 2>&1
    apt-get install -y dnsutils >/dev/null 2>&1
  fi

  check_domain() {
    local domain="$1"
    local resolved_ip
    local clean_domain

    clean_domain=$(echo "${domain}" | sed 's|https://||g' | sed 's|http://||g' | cut -d'/' -f1)
    resolved_ip=$(dig +short "${clean_domain}" @8.8.8.8)

    if [ -z "${resolved_ip}" ]; then
      printf "${YELLOW} >> AVISO: ${clean_domain} não retornou IP no DNS ainda.\n"
    elif [ "${resolved_ip}" != "${ip_atual}" ]; then
      printf "${YELLOW} >> AVISO: ${clean_domain} -> ${resolved_ip}, diferente do IP atual ${ip_atual}.\n"
    else
      printf "${GREEN} >> OK: ${clean_domain} aponta para ${resolved_ip} (mesmo IP da VPS).${WHITE}\n"
    fi
  }

  check_domain "${subdominio_backend}"
  check_domain "${subdominio_frontend}"

  printf "\n${WHITE} >> Continuando a instalação mesmo com possíveis avisos de DNS...\n"
  sleep 3
}

atualiza_vps() {
  banner
  printf "${WHITE} >> Atualizando sistema e pacotes...\n\n"
  {
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y
    apt-get upgrade -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold"
    apt-get install -y build-essential apparmor-utils python3 acl curl wget unzip software-properties-common ca-certificates gnupg lsb-release dnsutils
  } || trata_erro "atualiza_vps"
}

cria_deploy() {
  banner
  printf "${WHITE} >> Criando/ajustando usuário deploy...\n\n"
  {
    id deploy >/dev/null 2>&1 || useradd -m -s /bin/bash deploy
    echo "deploy:${senha_deploy}" | chpasswd
    usermod -aG sudo deploy

    mkdir -p /home/deploy
    chown -R deploy:deploy /home/deploy

    touch /home/deploy/.bashrc /home/deploy/.profile /home/deploy/.bash_profile /home/deploy/.npmrc
    chown deploy:deploy /home/deploy/.bashrc /home/deploy/.profile /home/deploy/.bash_profile /home/deploy/.npmrc
    chmod 644 /home/deploy/.bashrc /home/deploy/.profile /home/deploy/.bash_profile /home/deploy/.npmrc

    mkdir -p /home/deploy/.npm /home/deploy/.pm2
    chown -R deploy:deploy /home/deploy/.npm /home/deploy/.pm2

    sudo -u deploy bash -lc 'grep -q "export HOME=/home/deploy" ~/.bashrc || echo "export HOME=/home/deploy" >> ~/.bashrc'
    sudo -u deploy bash -lc 'grep -q "export PM2_HOME=/home/deploy/.pm2" ~/.bashrc || echo "export PM2_HOME=/home/deploy/.pm2" >> ~/.bashrc'
    sudo -u deploy bash -lc 'grep -q "/usr/local/bin" ~/.bashrc || echo "export PATH=/usr/local/bin:/usr/bin:\$PATH" >> ~/.bashrc'
  } || trata_erro "cria_deploy"
}

