VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:${email_deploy}
EOF

  chown deploy:deploy "${backend_dir}/.env"

  banner
  printf "${WHITE} >> Gerando chaves VAPID do backend...\n\n"

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    export PATH=/usr/local/bin:/usr/bin:\$PATH
    cd '${backend_dir}'

    VAPID_KEYS=\$(npx --yes web-push generate-vapid-keys --json 2>/dev/null || true)

    if [ -n \"\$VAPID_KEYS\" ]; then
      VAPID_PUB=\$(echo \"\$VAPID_KEYS\" | grep -o '\"publicKey\":\"[^\"]*\"' | cut -d'\"' -f4)
      VAPID_PRIV=\$(echo \"\$VAPID_KEYS\" | grep -o '\"privateKey\":\"[^\"]*\"' | cut -d'\"' -f4)

      if [ -n \"\$VAPID_PUB\" ] && [ -n \"\$VAPID_PRIV\" ]; then
        sed -i \"s|^VAPID_PUBLIC_KEY=.*|VAPID_PUBLIC_KEY=\$VAPID_PUB|\" '${backend_dir}/.env'
        sed -i \"s|^VAPID_PRIVATE_KEY=.*|VAPID_PRIVATE_KEY=\$VAPID_PRIV|\" '${backend_dir}/.env'
      fi
    fi
  "

  banner
  printf "${WHITE} >> Instalando dependências e buildando backend...\n\n"

  chown -R deploy:deploy /home/deploy/.npm 2>/dev/null || true
  chown deploy:deploy /home/deploy/.npmrc /home/deploy/.bashrc 2>/dev/null || true

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    export PATH=/usr/local/bin:/usr/bin:\$PATH
    export PM2_HOME=/home/deploy/.pm2
    cd '${backend_dir}'
    export PUPPETEER_SKIP_DOWNLOAD=true
    rm -rf node_modules dist 2>/dev/null || true
    npm config set cache /home/deploy/.npm --global >/dev/null 2>&1 || true

    if [ ! -f package-lock.json ]; then
      echo 'ERRO: package-lock.json não encontrado no backend.'
      exit 1
    fi

    npm ci --force
    npm run build
  " || trata_erro "npm_backend"

  banner
  printf "${WHITE} >> Rodando migrations e seeds do backend...\n\n"

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    export PATH=/usr/local/bin:/usr/bin:\$PATH
    export PM2_HOME=/home/deploy/.pm2
    cd '${backend_dir}'

    mkdir -p config

    cat > config/database.js <<'EOF'
require('dotenv/config');

module.exports = {
  dialect: process.env.DB_DIALECT || 'postgres',
  host: process.env.DB_HOST || 'localhost',
  port: process.env.DB_PORT ? parseInt(process.env.DB_PORT, 10) : 5432,
  username: process.env.DB_USER,
  password: process.env.DB_PASS,
  database: process.env.DB_NAME,
  define: {
    charset: 'utf8mb4',
    collate: 'utf8mb4_bin'
  },
  pool: {
    max: process.env.DB_POOL_MAX ? parseInt(process.env.DB_POOL_MAX, 10) : 100,
    min: process.env.DB_POOL_MIN ? parseInt(process.env.DB_POOL_MIN, 10) : 15,
    acquire: process.env.DB_POOL_ACQUIRE ? parseInt(process.env.DB_POOL_ACQUIRE, 10) : 30000,
    idle: process.env.DB_POOL_IDLE ? parseInt(process.env.DB_POOL_IDLE, 10) : 600000
  },
  logging: false
};
EOF

    npm run db:migrate
    npm run db:seed
  " || trata_erro "migrate_seed_backend"

  banner
  printf "${WHITE} >> Subindo backend com PM2...\n\n"

  sudo -u deploy bash -lc "
    export HOME=/home/deploy
    export PATH=/usr/local/bin:/usr/bin:\$PATH
    export PM2_HOME=/home/deploy/.pm2
    cd '${backend_dir}'

    pm2 delete '${empresa}-backend' 2>/dev/null || true
    pm2 start dist/server.js --name='${empresa}-backend' --update-env
    pm2 save
    pm2 list
  " || trata_erro "pm2_backend"
}

