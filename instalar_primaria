config_firewall() {
  banner
  printf "${WHITE} >> Liberando portas 80 e 443...\n\n"
  {
    if ! command -v ufw >/dev/null 2>&1; then
      apt-get install -y ufw >/dev/null 2>&1 || true
    fi
    ufw allow 80/tcp >/dev/null 2>&1 || true
    ufw allow 443/tcp >/dev/null 2>&1 || true
  } || true
}

