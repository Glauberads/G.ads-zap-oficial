instala_postgres() {
  banner
  printf "${WHITE} >> Instalando PostgreSQL 17...\n\n"
  {
    apt-get install -y gnupg wget lsb-release
    if [ ! -f /etc/apt/sources.list.d/pgdg.list ]; then
      echo "deb http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list
      wget --quiet -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add -
    fi
    apt-get update -y
    apt-get install -y postgresql-17 postgresql-client-17
    systemctl enable postgresql
    systemctl restart postgresql
  } || trata_erro "instala_postgres"
}

instala_node() {
  banner
  printf "${WHITE} >> Instalando Node.js 22 + npm...\n\n"
  {
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs

    ln -sf /usr/bin/node /usr/local/bin/node 2>/dev/null || true
    ln -sf /usr/bin/npm  /usr/local/bin/npm  2>/dev/null || true

    echo
    echo "Node: $(node -v 2>/dev/null) | npm: $(npm -v 2>/dev/null)"
    echo
    sleep 2
  } || trata_erro "instala_node"
}

instala_redis() {
  banner
  printf "${WHITE} >> Instalando e configurando Redis...\n\n"
  {
    apt-get install -y redis-server
    systemctl enable redis-server.service

    if grep -q '^# requirepass foobared' /etc/redis/redis.conf; then
      sed -i "s/^# requirepass foobared/requirepass ${senha_deploy}/" /etc/redis/redis.conf
    elif grep -q '^requirepass ' /etc/redis/redis.conf; then
      sed -i "s/^requirepass .*/requirepass ${senha_deploy}/" /etc/redis/redis.conf
    else
      echo "requirepass ${senha_deploy}" >> /etc/redis/redis.conf
    fi

    if grep -q '^appendonly no' /etc/redis/redis.conf; then
      sed -i 's/^appendonly no/appendonly yes/' /etc/redis/redis.conf
    fi

    systemctl restart redis-server.service
  } || trata_erro "instala_redis"
}

instala_pm2() {
  banner
  printf "${WHITE} >> Instalando e configurando PM2...\n\n"

  {
    export PATH=/usr/local/bin:/usr/bin:$PATH

    apt-get install -y logrotate >/dev/null 2>&1 || true

    if ! command -v node >/dev/null 2>&1; then
      instala_node
    fi

    rm -f /usr/local/bin/pm2 /usr/bin/pm2 2>/dev/null || true
    npm uninstall -g pm2 >/dev/null 2>&1 || true
    npm install -g pm2 --no-fund --no-audit

    PM2_REAL="$(npm root -g 2>/dev/null)/pm2/bin/pm2"
    if [ ! -f "$PM2_REAL" ]; then
      PM2_REAL="$(find "$(npm root -g 2>/dev/null)/pm2" -type f -name pm2 2>/dev/null | head -1)"
    fi

    [ -f "$PM2_REAL" ] || trata_erro "instala_pm2_binario"

    ln -sf "$PM2_REAL" /usr/local/bin/pm2
    ln -sf "$PM2_REAL" /usr/bin/pm2
    chmod +x "$PM2_REAL" /usr/local/bin/pm2 /usr/bin/pm2

    mkdir -p /home/deploy/.pm2
    chown -R deploy:deploy /home/deploy/.pm2
    chmod -R 755 /home/deploy/.pm2

    rm -f /home/deploy/.pm2/rpc.sock /home/deploy/.pm2/pub.sock /home/deploy/.pm2/pm2.pid 2>/dev/null || true
    rm -f /root/.pm2/rpc.sock /root/.pm2/pub.sock /root/.pm2/pm2.pid 2>/dev/null || true

    sudo -u deploy bash -lc '
      export HOME=/home/deploy
      export PATH=/usr/local/bin:/usr/bin:$PATH
      export PM2_HOME=/home/deploy/.pm2
      pm2 kill >/dev/null 2>&1 || true
      rm -f /home/deploy/.pm2/rpc.sock /home/deploy/.pm2/pub.sock /home/deploy/.pm2/pm2.pid 2>/dev/null || true
      pm2 -v >/dev/null 2>&1
    ' || trata_erro "instala_pm2_deploy"

    /usr/bin/pm2 startup systemd -u deploy --hp /home/deploy >/dev/null 2>&1 || true
    systemctl daemon-reload >/dev/null 2>&1 || true
  } || trata_erro "instala_pm2"
}

instala_nginx_certbot() {
  banner
  printf "${WHITE} >> Instalando Nginx + Certbot...\n\n"
  {
    apt-get install -y nginx
    rm -f /etc/nginx/sites-enabled/default

    if ! grep -q "client_max_body_size 100M;" /etc/nginx/nginx.conf; then
      sed -i 's/http {/http {\n\tclient_max_body_size 100M;/' /etc/nginx/nginx.conf
    fi

    apt-get install -y snapd
    snap install core >/dev/null 2>&1 || true
    snap refresh core >/dev/null 2>&1 || true
    apt-get remove -y certbot >/dev/null 2>&1 || true
    snap install --classic certbot >/dev/null 2>&1 || true
    ln -sf /snap/bin/certbot /usr/bin/certbot

    systemctl enable nginx
    systemctl restart nginx
  } || trata_erro "instala_nginx_certbot"
}

cria_banco() {
  banner
  printf "${WHITE} >> Criando banco e usuário Postgres...\n\n"
  {
    sudo -u postgres psql <<EOF
DO
\$do\$
BEGIN
   IF NOT EXISTS (
      SELECT FROM pg_catalog.pg_roles WHERE rolname = '${empresa}'
   ) THEN
      CREATE ROLE ${empresa} LOGIN SUPERUSER INHERIT CREATEDB CREATEROLE;
      ALTER USER ${empresa} PASSWORD '${senha_deploy}';
   ELSE
      ALTER USER ${empresa} PASSWORD '${senha_deploy}';
   END IF;
END
\$do\$;
EOF

    sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname = '${empresa}'" | grep -q 1 || sudo -u postgres createdb "${empresa}" -O "${empresa}"
  } || trata_erro "cria_banco"
}

