config_nginx() {
  banner
  printf "${WHITE} >> Configurando Nginx para frontend e backend...\n\n"

  local backend_clean frontend_clean
  backend_clean=$(echo "${subdominio_backend}" | sed 's|https://||g' | sed 's|http://||g' | cut -d'/' -f1)
  frontend_clean=$(echo "${subdominio_frontend}" | sed 's|https://||g' | sed 's|http://||g' | cut -d'/' -f1)

  cat > "/etc/nginx/sites-available/${empresa}-backend" <<EOF
upstream backend_app {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name ${backend_clean};
    client_max_body_size 100M;

    location ^~ /official-public/ {
        alias /home/deploy/${empresa}/api_oficial/public/;
        try_files \$uri =404;
        access_log off;
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    location /socket.io/ {
        proxy_pass http://backend_app/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_read_timeout 3600;
        proxy_send_timeout 3600;
        proxy_buffering off;
    }

    location / {
        proxy_pass http://backend_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF

  cat > "/etc/nginx/sites-available/${empresa}-frontend" <<EOF
server {
    listen 80;
    server_name ${frontend_clean};
    client_max_body_size 100M;

    location /public/ {
        proxy_pass http://127.0.0.1:8080/public/;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    }

    location /socket.io/ {
        proxy_pass http://127.0.0.1:8080/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_read_timeout 3600;
        proxy_send_timeout 3600;
        proxy_buffering off;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF

  ln -sf "/etc/nginx/sites-available/${empresa}-backend" /etc/nginx/sites-enabled/
  ln -sf "/etc/nginx/sites-available/${empresa}-frontend" /etc/nginx/sites-enabled/

  nginx -t || trata_erro "nginx_test"
  systemctl restart nginx

  banner
  printf "${WHITE} >> Emitindo SSL (backend: ${backend_clean})...\n\n"
  certbot -m "${email_deploy}" --nginx --agree-tos -n -d "${backend_clean}" || trata_erro "certbot_backend"

  banner
  printf "${WHITE} >> Emitindo SSL (frontend: ${frontend_clean})...\n\n"
  certbot -m "${email_deploy}" --nginx --agree-tos -n -d "${frontend_clean}" || trata_erro "certbot_frontend"

  systemctl restart nginx
}

