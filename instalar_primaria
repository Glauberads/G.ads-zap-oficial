prepara_origem_codigo() {
  banner
  printf "${WHITE} >> Preparando origem do código...\n\n"

  if [ -d "${SCRIPT_DIR}/backend" ] && [ -d "${SCRIPT_DIR}/frontend" ]; then
    export MULTIZAP_SRC_ROOT="${SCRIPT_DIR}"
    printf "${GREEN}>> OK: usando código diretamente do repositório clonado: ${YELLOW}${MULTIZAP_SRC_ROOT}${WHITE}\n"
    sleep 2
    return 0
  fi

  if [ -f "${SCRIPT_DIR}/Multizap.zip" ]; then
    if ! command -v unzip >/dev/null 2>&1; then
      apt-get update -y >/dev/null 2>&1
      apt-get install -y unzip >/dev/null 2>&1
    fi

    EXTRACT_DIR="${SCRIPT_DIR}/.multizap_extract"
    rm -rf "${EXTRACT_DIR}" 2>/dev/null || true
    mkdir -p "${EXTRACT_DIR}"

    unzip -o "${SCRIPT_DIR}/Multizap.zip" -d "${EXTRACT_DIR}" >/dev/null 2>&1 || trata_erro "extrair_zip"

    SRC_ROOT="${EXTRACT_DIR}"
    if [ -d "${EXTRACT_DIR}/Multizap/backend" ] || [ -d "${EXTRACT_DIR}/Multizap/frontend" ]; then
      SRC_ROOT="${EXTRACT_DIR}/Multizap"
    fi

    [ -d "${SRC_ROOT}/backend" ] && [ -d "${SRC_ROOT}/frontend" ] || trata_erro "estrutura_codigo"

    export MULTIZAP_SRC_ROOT="${SRC_ROOT}"
    printf "${GREEN}>> OK: usando código extraído do ZIP: ${YELLOW}${MULTIZAP_SRC_ROOT}${WHITE}\n"
    sleep 2
    return 0
  fi

  printf "${RED}ERRO: não encontrei backend/frontend no repositório atual nem o arquivo Multizap.zip.${WHITE}\n"
  exit 1
}

copia_codigo() {
  banner
  printf "${WHITE} >> Copiando backend, frontend, api_oficial e api_transcricao...\n\n"
  {
    mkdir -p "/home/deploy/${empresa}"

    [ -n "${MULTIZAP_SRC_ROOT}" ] || prepara_origem_codigo

    rm -rf "/home/deploy/${empresa}/backend" "/home/deploy/${empresa}/frontend" "/home/deploy/${empresa}/api_oficial" "/home/deploy/${empresa}/api_transcricao" 2>/dev/null || true

    cp -R "${MULTIZAP_SRC_ROOT}/backend" "/home/deploy/${empresa}/"
    cp -R "${MULTIZAP_SRC_ROOT}/frontend" "/home/deploy/${empresa}/"

    [ -d "${MULTIZAP_SRC_ROOT}/api_oficial" ] && cp -R "${MULTIZAP_SRC_ROOT}/api_oficial" "/home/deploy/${empresa}/"
    [ -d "${MULTIZAP_SRC_ROOT}/api_transcricao" ] && cp -R "${MULTIZAP_SRC_ROOT}/api_transcricao" "/home/deploy/${empresa}/"

    chown -R deploy:deploy "/home/deploy/${empresa}"
    chmod -R 775 "/home/deploy/${empresa}"

    rm -rf "${SCRIPT_DIR}/.multizap_extract" 2>/dev/null || true
  } || trata_erro "copia_codigo"
}

instala_serve_global() {
  banner
  printf "${WHITE} >> Instalando serve globalmente para servir o frontend...\n\n"

  {
    export PATH=/usr/local/bin:/usr/bin:$PATH

    rm -f /usr/bin/serve /usr/local/bin/serve 2>/dev/null || true
    npm install -g serve --no-fund --no-audit

    sudo -u deploy bash -lc 'grep -q "/usr/local/bin" ~/.bashrc || echo "export PATH=/usr/local/bin:/usr/bin:\$PATH" >> ~/.bashrc'

    cat > /usr/local/bin/serve-fallback <<'EOF'
#!/bin/bash
set -e
if command -v serve >/dev/null 2>&1; then
  exec serve "$@"
fi
if command -v npx >/dev/null 2>&1; then
  exec npx --yes serve "$@"
fi
echo "ERRO: nem serve nem npx disponíveis."
exit 1
EOF
    chmod +x /usr/local/bin/serve-fallback
  } || true
}

configura_backend() {
  banner
  printf "${WHITE} >> Configurando .env do backend...\n\n"

  local backend_dir="/home/deploy/${empresa}/backend"
  local backend_clean frontend_clean
  backend_clean=$(echo "${subdominio_backend}" | sed 's|https://||g' | sed 's|http://||g' | cut -d'/' -f1)
  frontend_clean=$(echo "${subdominio_frontend}" | sed 's|https://||g' | sed 's|http://||g' | cut -d'/' -f1)

  local backend_url="https://${backend_clean}"
  local frontend_url="https://${frontend_clean}"

  cat > "${backend_dir}/.env" <<EOF
NODE_ENV=production
BACKEND_URL=${backend_url}
FRONTEND_URL=${frontend_url}
URL_API_OFICIAL=
OFFICIAL_MEDIA_URL=${backend_url}
PROXY_PORT=443
PORT=8080

# Papel do processo
PROCESS_ROLE=all

# Socket.IO preparado para multi-processo / multi-instância
SOCKET_REDIS_ADAPTER=true
SOCKET_REDIS_EMITTER=true
SOCKET_ADMIN=false

# Bull Board
BULL_BOARD=false

DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=5432
DB_USER=${empresa}
DB_PASS=${senha_deploy}
DB_NAME=${empresa}
DB_POOL_MAX=100
DB_POOL_MIN=15
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=600000

REDIS_URI=redis://:${senha_deploy}@127.0.0.1:6379
REDIS_URI_ACK=redis://:${senha_deploy}@127.0.0.1:6379
REDIS_URI_MSG_CONN=redis://:${senha_deploy}@127.0.0.1:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBIT_USER=${empresa}
RABBIT_PASS=${senha_deploy}
RABBITMQ_URI=amqp://${empresa}:${senha_deploy}@localhost:5672/

TIMEOUT_TO_IMPORT_MESSAGE=1000

JWT_SECRET=${jwt_secret}
JWT_REFRESH_SECRET=${jwt_refresh_secret}
MASTER_KEY=${senha_master}

VERIFY_TOKEN=whaticket
FACEBOOK_APP_ID=${facebook_app_id}
FACEBOOK_APP_SECRET=${facebook_app_secret}

MP_ACCESS_TOKEN=
MP_NOTIFICATION_URL=${backend_url%/}/subscription/mercadopagowebhook

# EMAIL
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_SECURE="false"
MAIL_USER="seuemaildogmail"
MAIL_PASS="suasenhadeapp"
MAIL_FROM="Redefinição de senha <seuemaildogmail>"

USE_WHATSAPP_OFICIAL=false
TOKEN_API_OFICIAL="whaticket"
OFFICIAL_CAMPAIGN_CONCURRENCY=10

TRANSCRIBE_URL=http://127.0.0.1:4002

